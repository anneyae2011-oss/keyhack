# PostgreSQL (Neon recommended for Vercel)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NanaTwo Gateway master secret (used to sign gateway API keys)
GATEWAY_SECRET=your-super-secret-32-char-string-here

# Optional: default AI provider keys (can also be added via dashboard)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
